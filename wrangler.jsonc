{
    "$schema": "node_modules/wrangler/config-schema.json",
    "name": "ranklytics",
    "main": "src/index.js",
    "compatibility_date": "2024-03-01",
    "compatibility_flags": [
        "nodejs_compat"
    ],
    "assets": {
        "directory": "public",
        "binding": "ASSETS"
    },
    "observability": {
        "enabled": true
    }
    // "kv_namespaces": [
    //   {
    //     "binding": "RANKLYTICS_KV",
    //     "id": "YOUR_KV_NAMESPACE_ID"
    //   }
    // ]
}